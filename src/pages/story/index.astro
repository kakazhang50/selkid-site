---
import BaseLayout from '@/layouts/BaseLayout.astro';
import KdpBookGrid from '@/components/KdpBookGrid.astro';
import PageCTA from '@/components/PageCTA.astro';
import { kdp } from '@/lib/kdp-books';
import { pageJsonLdExtra } from '@/lib/seo';

const { author, series } = kdp;
const totalBooks = series.reduce((n, s) => n + s.books.length, 0);
const breadcrumbs = [
  { name: 'Home', href: 'https://selkid.com/' },
  { name: 'Stories for Young Readers', href: '/story/' },
];
---

<BaseLayout
  title="Stories for Young Readers"
  description={`Chapter books and read-aloud stories by ${author.name} on Amazon — Rex & Dino adventures and SEL stories from the SELKID world.`}
  canonical="https://story.selkid.com/"
  ogImage="/assets/hero-maple-forest.png"
  ogImageAlt="SELKID story world — Rex and Dino"
  pageType="CollectionPage"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={pageJsonLdExtra({ breadcrumbs })}
>
  <section class="page-hero refined">
    <div>
      <p class="eyebrow">story.selkid.com · KDP</p>
      <h1>Stories for young readers</h1>
      <p>
        Chapter books and picture books published on Amazon as <strong>{author.name}</strong> — the same story world as
        SELKID, written for bedtime, independent reading, and family read-alouds.
      </p>
      <div class="page-stats">
        <div class="stat-chip"><strong>{totalBooks}+</strong><span>titles on Amazon</span></div>
        <div class="stat-chip"><strong>{series.length}</strong><span>story series</span></div>
      </div>
      <div class="hero-actions">
        <a class="btn btn-primary" href={author.amazonStoreUrl} target="_blank" rel="noopener noreferrer">
          Browse on Amazon
        </a>
        <a class="btn btn-ghost" href="https://selkid.com/">SELKID classroom resources</a>
      </div>
    </div>
    <img src="/assets/hero-maple-forest.png" alt="Rex and Dino story world" />
  </section>

  <section class="section light">
    <div class="section-inner story-author-note">
      <p class="eyebrow">About {author.name}</p>
      <p>{author.bio}</p>
      <p class="story-bridge">
        Looking for classroom read-alouds, CASEL-aligned SEL packs, and TPT resources?
        <a href="https://selkid.com/sel-stories/">Explore SEL Stories on SELKID.com</a>
        — same heart, built for educators.
      </p>
    </div>
  </section>

  {
    series.map((s) => (
      <section class="section white" id={s.id}>
        <div class="section-inner">
          <div class="section-heading section-heading--compact">
            <p class="eyebrow">Series</p>
            <h2>{s.title}</h2>
            <p>{s.tagline}</p>
            {s.brandLink && (
              <a class="btn btn-ghost btn--tight" href={s.brandLink}>
                Meet Rex &amp; Dino on SELKID
              </a>
            )}
          </div>
          <KdpBookGrid books={s.books} storeUrl={author.amazonStoreUrl} />
        </div>
      </section>
    ))
  }

  <PageCTA
    title="Read a story tonight"
    description="All titles are available on Amazon Kindle and select print editions."
    links={[
      { href: author.amazonStoreUrl, label: `Visit ${author.name} on Amazon`, external: true },
      { href: 'https://selkid.com/free-resources#subscribe', label: 'SELKID free sample', variant: 'secondary' },
    ]}
  />
</BaseLayout>
