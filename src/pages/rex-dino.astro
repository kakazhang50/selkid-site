---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageCTA from '@/components/PageCTA.astro';
import { pageJsonLdExtra } from '@/lib/seo';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Rex & Dino', href: '/rex-dino' },
];
---

<BaseLayout
  title="Rex & Dino"
  description="Meet Rex, Dino, Atlas, and the SELKID cast in Maple Forest — story-led characters for SEL, thinking skills, and AI cognition in K–6."
  ogImage="/assets/hero-maple-forest.png"
  ogImageAlt="Rex and Dino in Maple Forest"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={pageJsonLdExtra({ breadcrumbs })}
>
  <section class="page-hero refined">
    <div>
      <p class="eyebrow">Character-led learning</p>
      <h1>Rex reacts. Dino reframes. Children think.</h1>
      <p>
        Rex &amp; Dino began inside SELKID's story-based learning world and now carry the brand from SEL foundations into
        AI cognition. They make difficult ideas feel like adventures, not lectures.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/free-resources#subscribe">Get free sample</a>
        <a class="btn btn-secondary" href="/ai-cognition">AI Cognition series</a>
        <a class="btn btn-ghost" href="/learning-system">Learning System</a>
      </div>
    </div>
    <img src="/assets/hero-maple-forest.png" alt="Rex and Dino in Maple Forest" />
  </section>

  <section class="section white">
    <div class="section-inner">
      <div class="section-heading centered section-heading--compact">
        <p class="eyebrow">The cast</p>
        <h2>Six characters, one story world</h2>
      </div>
      <div class="character-grid premium">
        <article>
          <span>Rex</span>
          <h2>The first reaction</h2>
          <p>
            Curious, fast, emotional, and honest. Rex represents the child's first impulse—trusting the shiny tool,
            jumping to a conclusion, or asking the brave question.
          </p>
        </article>
        <article>
          <span>Dino</span>
          <h2>The second thought</h2>
          <p>
            Dino brings humor, warmth, and reframing. He slows the moment down without turning it into a lesson that
            feels heavy.
          </p>
        </article>
        <article>
          <span>Atlas</span>
          <h2>The evidence keeper</h2>
          <p>
            Atlas Tortoise models verification, patience, and careful judgment—the core human skills children need around
            AI.
          </p>
        </article>
        <article>
          <span>Mayor Owl</span>
          <h2>The community guide</h2>
          <p>Classroom rules, group problems, and the shared life of Maple Forest.</p>
        </article>
        <article>
          <span>Mimi Rabbit</span>
          <h2>Speed &amp; common samples</h2>
          <p>Quick movement and the perspective of what is most common — a lens for bias and missing voices.</p>
        </article>
        <article>
          <span>Maple Forest</span>
          <h2>The story world</h2>
          <p>
            Maple Forest turns abstract ideas into memorable choices—a place built to grow across comics, animation,
            audiobooks, and classroom media.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="world-band light">
    <div class="section-heading centered section-heading--compact">
      <p class="eyebrow">Inside the comic</p>
      <h2>Where everyday problems become learning adventures.</h2>
    </div>
    <p>Rex &amp; Dino live in Maple Forest—see them discover training data, bias, and human judgment in kid-sized comic stories.</p>
    <a class="world-band-link" href="/free-resources">
      <img src="/assets/comics/training-data-p1.png" alt="Rex and Dino Training Data comic page" />
    </a>
  </section>

  <PageCTA
    title="Meet Rex &amp; Dino in the classroom"
    description="Start with the free Unit 1 comic sample, then explore SEL stories and the full AI cognition series."
    links={[
      { href: '/free-resources#subscribe', label: 'Get free sample' },
      { href: '/sel-stories', label: 'SEL Stories', variant: 'secondary' },
      { href: '/ai-cognition', label: 'AI Cognition', variant: 'ghost' },
    ]}
  />
</BaseLayout>
