---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandBelief from '@/components/BrandBelief.astro';
import PageCTA from '@/components/PageCTA.astro';
import { site } from '@/lib/site';
import { catalog } from '@/lib/catalog';
import { pageJsonLdExtra, siteFaqs } from '@/lib/seo';

const total = catalog.totalProducts || catalog.products.length;
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
];
---

<BaseLayout
  title="About"
  description={`${site.brandName} teaches social-emotional learning through story — ${total}+ CASEL-aligned read-alouds, thinking skills, and Rex & Dino AI cognition for K–6.`}
  pageType="AboutPage"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={pageJsonLdExtra({ breadcrumbs, faqs: siteFaqs.slice(0, 4) })}
>
  <section class="page-hero refined page-hero--solo">
    <div>
      <p class="eyebrow">About SELKID</p>
      <h1>Skills, not shame.</h1>
      <BrandBelief compact />
      <p>
        SELKID began with social-emotional learning stories for real classroom moments — blurting, waiting, big
        feelings, friendship repair. Its next chapter is AI cognition: helping children understand how technology
        learns, fails, and still needs human judgment.
      </p>
      <p class="page-hero-tagline">{site.tagline}</p>
      <dl class="entity-facts">
        <div>
          <dt>Brand</dt>
          <dd>{site.brandName}</dd>
        </div>
        <div>
          <dt>Focus</dt>
          <dd>SEL, thinking skills, AI cognition for K–6</dd>
        </div>
        <div>
          <dt>Resources</dt>
          <dd>{total}+ classroom stories on Teachers Pay Teachers</dd>
        </div>
        <div>
          <dt>Characters</dt>
          <dd>Rex, Dino, Atlas, Mayor Owl, Mimi Rabbit · Maple Forest</dd>
        </div>
        <div>
          <dt>Teaching model</dt>
          <dd>Story → Discussion → Activity → Reflection</dd>
        </div>
        <div>
          <dt>Free sample</dt>
          <dd><a href="/free-resources">Unit 1: Training Data — 16-panel comic + lesson guides</a></dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="section white">
    <div class="section-inner">
      <div class="section-heading centered section-heading--compact">
        <p class="eyebrow">What we believe</p>
        <h2>Three commitments</h2>
      </div>
      <div class="manifesto manifesto--inline">
        <article>
          <span>01</span>
          <h2>Belief first</h2>
          <p>
            We treat emotional struggle as a teachable moment, not a character flaw. Stories give children language, Rex
            &amp; Dino give them a mirror, and teachers get a no-prep path from feeling to skill.
          </p>
        </article>
        <article>
          <span>02</span>
          <h2>AI future</h2>
          <p>AI is treated as a powerful tool with limits, not as magic, authority, or a replacement for responsibility.</p>
        </article>
        <article>
          <span>03</span>
          <h2>IP-centered</h2>
          <p>
            Rex &amp; Dino are built to become a durable learning world across comics, books, audio, animation, and
            educational products.
          </p>
        </article>
      </div>
    </div>
  </section>

  <PageCTA
    title="Explore the SELKID world"
    description={`${catalog.pillars.sel} SEL stories, ${catalog.pillars.thinking} thinking skills kits, and a growing AI cognition series — all on Teachers Pay Teachers.`}
    links={[
      { href: '/sel-stories', label: 'SEL Stories' },
      { href: '/free-resources#subscribe', label: 'Get free sample', variant: 'secondary' },
      { href: site.tptStore, label: 'TPT Store', external: true, variant: 'ghost' },
    ]}
  />
</BaseLayout>
