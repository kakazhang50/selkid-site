---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandBelief from '@/components/BrandBelief.astro';
import { site } from '@/lib/site';
import { catalog } from '@/lib/catalog';
---

<BaseLayout title="About" description="SELKID believes emotional struggle isn't a mistake — it's a skill waiting to be taught. 200+ CASEL-aligned stories for K–6.">
  <section class="about-hero">
    <p class="eyebrow">About SELKID</p>
    <h1>Skills, not shame.</h1>
    <BrandBelief compact />
    <p style="margin-top:24px">SELKID began with social-emotional learning stories for real classroom moments — blurting, waiting, big feelings, friendship repair. Its next chapter is AI cognition: helping children understand how technology learns, fails, and still needs human judgment.</p>
    <p style="margin-top:16px;font-family:var(--font-display);font-size:1.2rem;color:var(--terracotta)">{site.tagline}</p>
  </section>

  <section class="manifesto">
    <article><span>01</span><h2>Belief first</h2><p>We treat emotional struggle as a teachable moment, not a character flaw. Stories give children language, Rex &amp; Dino give them a mirror, and teachers get a no-prep path from feeling to skill.</p></article>
    <article><span>02</span><h2>AI future</h2><p>AI is treated as a powerful tool with limits, not as magic, authority, or a replacement for responsibility.</p></article>
    <article><span>03</span><h2>IP-centered</h2><p>Rex &amp; Dino are built to become a durable learning world across comics, books, audio, animation, and educational products.</p></article>
  </section>

  <section class="cta-band">
    <h2>Explore the SELKID world</h2>
    <p>{catalog.pillars.sel} SEL stories, {catalog.pillars.thinking} thinking skills kits, and a growing AI cognition series—all on Teachers Pay Teachers.</p>
    <div class="hero-actions" style="justify-content:center">
      <a class="btn btn-primary" href="/sel-stories">SEL Stories</a>
      <a class="btn btn-secondary" href={site.tptStore} target="_blank" rel="noopener">TPT Store</a>
    </div>
  </section>
</BaseLayout>
