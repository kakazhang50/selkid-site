---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CaselFramework from '@/components/CaselFramework.astro';
import EducationMatrix from '@/components/EducationMatrix.astro';
import SelFrameworkExplainer from '@/components/SelFrameworkExplainer.astro';
import StepsGrid from '@/components/StepsGrid.astro';
import BeliefBand from '@/components/BeliefBand.astro';
import SubscribeCTA from '@/components/SubscribeCTA.astro';
import { catalog } from '@/lib/catalog';
import { site, freeSample } from '@/lib/site';

const total = catalog.totalProducts || catalog.products.length;
---

<BaseLayout title="Learning System" description="SELKID's CASEL-aligned learning system: emotional struggle is a skill gap, not a mistake — 228+ story resources for K–6.">
  <section class="page-hero refined">
    <div>
      <p class="eyebrow">Learning System</p>
      <h1>{site.brandBeliefLead}</h1>
      <p class="page-hero-belief-sub">{site.brandBeliefSub}</p>
      <p>
        Built on the <strong>CASEL Framework</strong> and delivered through Rex &amp; Dino stories — SEL for K–2,
        thinking skills, and a flagship AI cognition series for Grades 3–6.
      </p>
      <div class="page-stats">
        <div class="stat-chip"><strong>5</strong><span>CASEL competencies</span></div>
        <div class="stat-chip"><strong>{total}+</strong><span>Resources on TPT</span></div>
        <div class="stat-chip"><strong>{catalog.pillars.ai}</strong><span>AI Cognition units</span></div>
      </div>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/free-resources#subscribe">Get free sample</a>
        <a class="btn btn-ghost" href="#casel">CASEL framework</a>
      </div>
    </div>
    <img src="/assets/hero-maple-forest.png" alt="Rex and Dino in Maple Forest" />
  </section>

  <section class="section white">
    <div class="section-inner">
      <div class="section-heading centered section-heading--compact">
        <p class="eyebrow">Brand progression</p>
        <h2>From feelings, to thinking, to the future</h2>
      </div>
      <EducationMatrix />
    </div>
  </section>

  <section class="section light" id="casel">
    <div class="section-inner">
      <CaselFramework />
    </div>
  </section>

  <section class="section white" id="sel-matrix">
    <div class="section-inner">
      <div class="section-heading centered section-heading--compact">
        <p class="eyebrow">SEL methodology</p>
        <h2>From CASEL competency to classroom moment</h2>
        <p>
          Once you know the CASEL lane, SELKID's matrix helps you find the exact story — by scenario, trigger, emotion,
          and skill.
        </p>
      </div>
      <SelFrameworkExplainer />
    </div>
  </section>

  <section class="steps section light">
    <div class="section-inner">
      <div class="section-heading centered section-heading--compact">
        <p class="eyebrow">Delivery model</p>
        <h2>Story → Discussion → Activity → Reflection</h2>
        <p>Every SELKID resource follows the same classroom rhythm teachers can use immediately.</p>
      </div>
      <StepsGrid />
    </div>
  </section>

  <BeliefBand />

  <SubscribeCTA
    context="learning-system"
    eyebrow="For educators"
    title="Get new stories &amp; free samples"
    description={`Join the SELKID list for the free ${freeSample.unitTitle} sample — full 16-panel comic plus partial lesson guides.`}
    buttonLabel="Get free sample"
  />
</BaseLayout>
