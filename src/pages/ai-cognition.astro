---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AiUnitsGrid from '@/components/AiUnitsGrid.astro';
import SubscribeCTA from '@/components/SubscribeCTA.astro';
import { site, freeSample } from '@/lib/site';
import { catalog } from '@/lib/catalog';
import { pageJsonLdExtra, siteFaqs } from '@/lib/seo';

const total = catalog.totalProducts || catalog.products.length;
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'AI Cognition', href: '/ai-cognition' },
];
const aiFaqs = siteFaqs.filter((faq) =>
  /Big AI Ideas|free sample|grade levels/i.test(faq.question)
);
---

<BaseLayout
  title="AI Cognition"
  description="Rex & Dino's Big AI Ideas — a comic-first AI cognition series for Grades 3–6. Six units on training data, bias, hallucination, and human judgment."
  ogImage="/assets/ai/unit6-cover.png"
  ogImageAlt="Rex and Dino AI Cognition — Human Judgment unit cover"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={pageJsonLdExtra({ breadcrumbs, faqs: aiFaqs })}
>
  <section class="page-hero refined ai-hero">
    <div>
      <p class="eyebrow">R&amp;D flagship · Grades 3–6</p>
      <h1>Rex &amp; Dino's Big AI Ideas</h1>
      <p class="lead">
        Not coding. Not tool training. <strong>Human judgment.</strong> A comic-first AI cognition series helping
        children understand how AI learns, why it makes mistakes, and why people still matter.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/free-resources#subscribe">Get free sample</a>
        <a class="btn btn-secondary" href={site.tptStore} target="_blank" rel="noopener">Shop on TPT</a>
      </div>
      <p class="page-hero-note">{freeSample.shortLead}</p>
    </div>
    <img src="/assets/ai/unit6-cover.png" alt="Human Judgment — AI cognition cover" />
  </section>

  <section class="rd-banner">
    <div class="rd-banner-inner">
      <span class="rd-badge">Active R&amp;D</span>
      <p>
        Season 1: <strong>AI Mistakes &amp; Human Judgment</strong> — SELKID's strategic growth engine, built on {total}+
        published classroom resources and the Rex &amp; Dino IP.
      </p>
    </div>
  </section>

  <section class="section white">
    <div class="section-inner">
      <div class="section-heading centered section-heading--compact">
        <p class="eyebrow">The framework</p>
        <h2>Learn → Fail → Judge</h2>
      </div>
      <div class="framework framework--inline">
        <div>
          <span>01</span>
          <h2>How AI learns</h2>
          <p>Children understand that AI systems learn from examples — not magic.</p>
        </div>
        <div>
          <span>02</span>
          <h2>Why AI fails</h2>
          <p>Bad data, missing groups, false confidence, and repeated copying.</p>
        </div>
        <div>
          <span>03</span>
          <h2>Why people matter</h2>
          <p>Checking evidence, context, and taking responsibility.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="section-inner">
      <div class="section-heading centered section-heading--compact">
        <p class="eyebrow">Season One curriculum</p>
        <h2>Six units. One judgment framework.</h2>
      </div>
      <AiUnitsGrid />
    </div>
  </section>

  <section class="quote-section">
    <blockquote>
      Children should not grow up believing AI is magic, neutral, or always right. They should grow up with stories that
      make AI understandable, questionable, and human-centered.
    </blockquote>
  </section>

  <SubscribeCTA
    dark
    context="ai-cognition"
    title="Be first to get new AI units"
    description={freeSample.ctaDescription}
    buttonLabel="Get free sample"
    eyebrow=""
  />
</BaseLayout>
