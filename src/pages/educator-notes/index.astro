---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageCTA from '@/components/PageCTA.astro';
import { getCollection } from 'astro:content';
import { pageJsonLdExtra } from '@/lib/seo';

const notes = (await getCollection('educatorNotes')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = notes.filter((n) => n.data.featured);
const rest = notes.filter((n) => !n.data.featured);
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Educator Notes', href: '/educator-notes' },
];
---

<BaseLayout
  title="Educator Notes"
  description="Classroom ideas, SEL practice, and AI cognition context from SELKID — practical essays for teachers using story-first learning."
  ogImage="/assets/comics/training-data-p1.png"
  ogImageAlt="Rex and Dino comic — Educator Notes"
  pageType="CollectionPage"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={pageJsonLdExtra({ breadcrumbs })}
>
  <section class="page-hero refined">
    <div>
      <p class="eyebrow">Educator Notes</p>
      <h1>Ideas from the Maple Forest desk</h1>
      <p>
        Short essays on SEL rhythm, classroom use, and why Rex &amp; Dino carry big ideas in kid-sized stories. No fluff
        — practical notes you can use this week.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/free-resources#subscribe">Get free sample</a>
        <a class="btn btn-ghost" href="/learning-system">Learning System</a>
      </div>
    </div>
    <img src="/assets/comics/training-data-p1.png" alt="Rex and Dino comic" />
  </section>

  <section class="section white">
    <div class="section-inner note-index">
      <p class="note-index-intro">
        <strong>For educators:</strong> product news stays on <a href="/free-resources">Free Resources</a>; deep classroom
        context lives here.
      </p>

      {
        featured.length > 0 && (
          <>
            <h2 class="note-section-title">Featured</h2>
            <ul class="note-list">
              {featured.map((note) => (
                <li class="note-card note-card--featured">
                  <p class="eyebrow">{note.data.category}</p>
                  <h3>
                    <a href={`/educator-notes/${note.slug}`}>{note.data.title}</a>
                  </h3>
                  <p>{note.data.description}</p>
                  <time datetime={note.data.pubDate.toISOString()}>
                    {note.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                </li>
              ))}
            </ul>
          </>
        )
      }

      {
        rest.length > 0 && (
          <>
            <h2 class="note-section-title">More notes</h2>
            <ul class="note-list">
              {rest.map((note) => (
                <li class="note-card">
                  <h3>
                    <a href={`/educator-notes/${note.slug}`}>{note.data.title}</a>
                  </h3>
                  <p>{note.data.description}</p>
                  <time datetime={note.data.pubDate.toISOString()}>
                    {note.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                </li>
              ))}
            </ul>
          </>
        )
      }
    </div>
  </section>

  <PageCTA
    title="Put ideas into practice"
    description="Get the free Unit 1 comic sample and classroom downloads — then browse SEL stories matched to your students."
    links={[
      { href: '/free-resources#subscribe', label: 'Get free sample' },
      { href: '/sel-stories', label: 'SEL Stories', variant: 'secondary' },
      { href: '/ai-cognition', label: 'AI Cognition', variant: 'ghost' },
    ]}
  />
</BaseLayout>
