---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { absoluteUrl, pageJsonLdExtra } from '@/lib/seo';

export async function getStaticPaths() {
  const notes = await getCollection('educatorNotes');
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
const all = (await getCollection('educatorNotes')).sort(
  (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
);
const idx = all.findIndex((n) => n.slug === note.slug);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;

const articleUrl = absoluteUrl(`/educator-notes/${note.slug}`);
const publishedTime = note.data.pubDate.toISOString();
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Educator Notes', href: '/educator-notes' },
  { name: note.data.title, href: `/educator-notes/${note.slug}` },
];
---

<BaseLayout
  title={note.data.title}
  description={note.data.description}
  ogType="article"
  ogImage="/assets/comics/training-data-p1.png"
  ogImageAlt={`Educator Note: ${note.data.title}`}
  publishedTime={publishedTime}
  breadcrumbs={breadcrumbs}
  jsonLdExtra={pageJsonLdExtra({
    breadcrumbs,
    article: {
      title: note.data.title,
      description: note.data.description,
      url: articleUrl,
      datePublished: publishedTime,
      category: note.data.category,
    },
  })}
>
  <article class="note-article" itemscope itemtype="https://schema.org/Article">
    <header class="note-article-header">
      <p class="eyebrow">Educator Note · {note.data.category}</p>
      <h1 itemprop="headline">{note.data.title}</h1>
      <p class="note-lead" itemprop="description">{note.data.description}</p>
      <time datetime={publishedTime} itemprop="datePublished">
        {
          note.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })
        }
      </time>
    </header>
    <div class="note-prose" itemprop="articleBody">
      <Content />
    </div>
    <nav class="note-nav" aria-label="Educator notes">
      {prev ? <a href={`/educator-notes/${prev.slug}`}>← {prev.data.title}</a> : <span />}
      <a href="/educator-notes">All notes</a>
      {next ? <a href={`/educator-notes/${next.slug}`}>{next.data.title} →</a> : <span />}
    </nav>
    <p class="note-article-cta">
      <a class="btn btn-primary" href="/free-resources#subscribe">Get free sample</a>
      <a class="btn btn-ghost" href="/sel-stories">Browse SEL stories</a>
    </p>
  </article>
</BaseLayout>
