---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CatalogMatrixFilters from '@/components/CatalogMatrixFilters.astro';
import PageCTA from '@/components/PageCTA.astro';
import { catalog, coverSrc } from '@/lib/catalog';

const products = catalog.products.filter((p) => p.pillar === 'thinking');
const heroProduct = products.find((p) => p.coverUrl) || products[0];
const heroImg = heroProduct ? coverSrc(heroProduct) : '/assets/covers/sel-waiting-cover.png';
---

<BaseLayout
  title="Thinking Skills"
  description="SELKID thinking skills stories help K-2 students practice big-picture thinking, flexible thinking, and evidence habits."
>
  <section class="page-hero refined">
    <div>
      <p class="eyebrow">Thinking Skills · Pillar 2</p>
      <h1>From feelings to thinking</h1>
      <p>
        {catalog.pillars.thinking} Rex &amp; Dino Cognitive Fables that bridge SEL and AI-age judgment — query by thinking
        habit, classroom scenario, and the feeling that gets in the way.
      </p>
      <div class="page-stats">
        <div class="stat-chip"><strong>{catalog.pillars.thinking}</strong><span>Read-alouds</span></div>
        <div class="stat-chip"><strong>5</strong><span>Thinking habits</span></div>
        <div class="stat-chip"><strong>K–2</strong><span>Classroom ready</span></div>
      </div>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#matrix-filters">Browse stories</a>
        <a class="btn btn-ghost" href="/learning-system#sel-matrix">See full learning system</a>
      </div>
    </div>
    <img src={heroImg} alt="Thinking skills story cover" />
  </section>

  <section class="section white section--flush-top">
    <CatalogMatrixFilters pillar="thinking" />
  </section>

  <PageCTA
    title="Bridge SEL and judgment"
    description="Thinking skills connect emotional regulation to the habits children need in an AI-shaped world."
    links={[
      { href: '/sel-stories', label: 'SEL Stories' },
      { href: '/ai-cognition', label: 'AI Cognition', variant: 'secondary' },
      { href: '/free-resources#subscribe', label: 'Get free sample', variant: 'ghost' },
    ]}
  />
</BaseLayout>
