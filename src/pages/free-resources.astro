---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SubscribeForm from '@/components/SubscribeForm.astro';
import PageCTA from '@/components/PageCTA.astro';
import { freeSample } from '@/lib/site';
import { catalog } from '@/lib/catalog';
import { pageJsonLdExtra } from '@/lib/seo';

const total = catalog.totalProducts || catalog.products.length;
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Free Resources', href: '/free-resources' },
];
const pageDescription = `Get ${freeSample.unitTitle} free — the full 16-panel Rex & Dino comic plus partial lesson guides. Free sample for K–6 educators and parents.`;
---

<BaseLayout
  title="Free Resources"
  description={pageDescription}
  ogImage="/assets/ai/unit1-cover.png"
  ogImageAlt="Rex and Dino Training Data — free Unit 1 sample cover"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={pageJsonLdExtra({ breadcrumbs })}
>
  <section class="subscribe-hero">
    <div class="subscribe-hero-grid">
      <div>
        <p class="eyebrow">Free Resources</p>
        <h1>Start with Training Data</h1>
        <p class="lead">
          The first unit of <strong>Rex &amp; Dino's Big AI Ideas</strong> — {freeSample.shortLead}
        </p>
        <ul class="subscribe-perks subscribe-perks--stacked">
          {
            freeSample.listPerks.map((perk) => (
              <li>{perk}</li>
            ))
          }
        </ul>
        <SubscribeForm
          id="subscribe"
          class="subscribe-form--hero"
          context="free-resources"
          placeholder="Teacher or parent email"
          buttonLabel="Get free sample"
        />
        <p class="form-fine">No spam. Unsubscribe anytime.</p>
        <p class="form-fine free-sample-full-note">{freeSample.fullEditionNote}</p>
      </div>
      <div class="subscribe-hero-art">
        <img src="/assets/ai/unit1-cover.png" alt="Training Data unit cover" />
        <img class="subscribe-comic-inset" src="/assets/comics/training-data-p1.png" alt="Training Data comic preview" />
      </div>
    </div>
  </section>

  <section class="steps section light">
    <div class="section-inner">
      <div class="section-heading centered section-heading--compact">
        <p class="eyebrow">What's in the free sample</p>
        <h2>Full Unit 1 comic + partial lesson guides</h2>
        <p>{freeSample.fullEditionNote}</p>
      </div>
      <div class="steps-grid">
        {
          freeSample.sampleIncludes.map((item) => (
            <article class="step-card">
              <span class="step-num">{item.icon}</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <PageCTA
    title="Ready for the full series?"
    description={`Explore all six AI cognition units or browse ${total}+ SEL resources on TPT.`}
    links={[
      { href: '/ai-cognition', label: 'AI Cognition Series' },
      { href: '/sel-stories', label: 'SEL Stories', variant: 'secondary' },
      { href: '/learning-system', label: 'Learning System', variant: 'ghost' },
    ]}
  />
</BaseLayout>
