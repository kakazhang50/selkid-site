---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CatalogMatrixFilters from '@/components/CatalogMatrixFilters.astro';
import SelFrameworkExplainer from '@/components/SelFrameworkExplainer.astro';
import PageCTA from '@/components/PageCTA.astro';
import { catalog } from '@/lib/catalog';

const caselCounts = catalog.facetCounts?.casel || {};
---

<BaseLayout
  title="SEL Stories"
  description="210+ CASEL-aligned SELKID social-emotional learning stories — query by competency, scenario, trigger, emotion, and skill."
>
  <section class="page-hero refined">
    <div>
      <p class="eyebrow">SEL Foundation · CASEL-aligned · Pillar 1</p>
      <h1>SEL Stories</h1>
      <p>
        {catalog.pillars.sel} stories built on the <strong>CASEL Framework</strong>, organized as{' '}
        <strong>Scenario × Trigger × Emotion × Skill</strong> — professional competencies delivered through Rex &amp; Dino
        read-alouds, not random worksheets.
      </p>
      <div class="page-stats">
        <div class="stat-chip"><strong>{catalog.pillars.sel}</strong><span>SEL stories</span></div>
        <div class="stat-chip"><strong>5</strong><span>CASEL competencies</span></div>
        <div class="stat-chip"><strong>{caselCounts['self-management'] || 0}</strong><span>Self-Management tagged</span></div>
      </div>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#matrix-filters">Browse stories</a>
        <a class="btn btn-ghost" href="/learning-system#casel">How CASEL powers SELKID</a>
      </div>
    </div>
    <img src="/assets/covers/sel-waiting-cover.png" alt="SELKID social story cover" />
  </section>

  <section class="section light" id="sel-matrix">
    <div class="section-inner">
      <div class="section-heading centered section-heading--compact">
        <p class="eyebrow">Find the right story</p>
        <h2>Scenario × Trigger × Emotion × Skill</h2>
      </div>
      <SelFrameworkExplainer />
    </div>
  </section>

  <section class="section white section--flush-top">
    <CatalogMatrixFilters pillar="sel" />
  </section>

  <PageCTA
    title="New to SELKID?"
    description="Get the free Unit 1 sample — full 16-panel comic plus partial lesson guides — or explore how the learning system works."
    links={[
      { href: '/free-resources#subscribe', label: 'Get free sample' },
      { href: '/learning-system', label: 'Learning System', variant: 'secondary' },
      { href: '/thinking-skills', label: 'Thinking Skills', variant: 'ghost' },
    ]}
  />
</BaseLayout>
