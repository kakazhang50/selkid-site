---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CatalogMatrixFilters from '@/components/CatalogMatrixFilters.astro';
import PageCTA from '@/components/PageCTA.astro';
import { catalog } from '@/lib/catalog';
import { pageJsonLdExtra } from '@/lib/seo';

const caselCounts = catalog.facetCounts?.casel || {};
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'SEL Stories', href: '/sel-stories' },
];
---

<BaseLayout
  title="SEL Stories"
  description={`Browse ${catalog.pillars.sel}+ CASEL-aligned SEL read-alouds for K–2 — filter by scenario, trigger, emotion, and skill. Rex & Dino social-emotional learning stories.`}
  ogImage="/assets/covers/sel-waiting-cover.png"
  ogImageAlt="SELKID social-emotional learning story cover"
  pageType="CollectionPage"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={pageJsonLdExtra({ breadcrumbs })}
>
  <section class="page-hero refined page-hero--catalog">
    <div>
      <p class="eyebrow">SEL Foundation · CASEL-aligned</p>
      <h1>SEL Stories</h1>
      <p>
        {catalog.pillars.sel} read-alouds — find by topic, search, or matrix. Each resource has a preview page with a
        direct link to Teachers Pay Teachers.
      </p>
      <div class="page-stats">
        <div class="stat-chip"><strong>{catalog.pillars.sel}</strong><span>SEL stories</span></div>
        <div class="stat-chip"><strong>5</strong><span>CASEL competencies</span></div>
        <div class="stat-chip"><strong>{caselCounts['self-management'] || 0}</strong><span>Self-Management</span></div>
      </div>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#matrix-filters">Browse all stories</a>
        <a class="btn btn-ghost" href="/learning-system#sel-matrix">How the matrix works</a>
      </div>
    </div>
    <img src="/assets/covers/sel-waiting-cover.png" alt="SELKID social story cover" />
  </section>

  <CatalogMatrixFilters pillar="sel" />

  <PageCTA
    title="New to SELKID?"
    description="Get the free Unit 1 sample — full 16-panel comic plus partial lesson guides — or explore how the learning system works."
    links={[
      { href: '/free-resources#subscribe', label: 'Get free sample' },
      { href: '/learning-system', label: 'Learning System', variant: 'secondary' },
      { href: '/thinking-skills', label: 'Thinking Skills', variant: 'ghost' },
    ]}
  />
</BaseLayout>
