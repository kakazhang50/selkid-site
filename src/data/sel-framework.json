{
  "title": "SELKID SEL Matrix",
  "subtitle": "Scenario × Trigger × Emotion × Skill",
  "brandBelief": "For every child, emotional struggle isn't a mistake — it's a skill waiting to be taught.",
  "philosophy": "SELKID starts from a simple belief: big feelings aren't bad behavior; they're skills still learning to grow. From there we use the CASEL Framework — the professional standard for SEL in U.S. schools — and map each competency into classroom scenarios, triggers, emotions, and teachable skills. That is how 200+ stories form one queryable system.",
  "caselNote": "Every SELKID story maps to one or more CASEL core competencies — the same framework used by schools and districts across the United States.",
  "caselFramework": {
    "name": "CASEL Framework",
    "shortName": "CASEL",
    "tagline": "The professional standard for SEL in U.S. schools",
    "attribution": "SELKID is built around the five core competencies defined by the Collaborative for Academic, Social, and Emotional Learning (CASEL) — then translated into kid-sized stories for real K–2 classrooms.",
    "referenceLabel": "Learn about CASEL",
    "referenceUrl": "https://casel.org/fundamentals-of-sel/what-is-the-casel-framework/",
    "methodology": [
      {
        "step": "1",
        "title": "Start with CASEL",
        "text": "Each resource targets an evidence-based competency — self-awareness, self-management, social awareness, relationship skills, or responsible decision-making."
      },
      {
        "step": "2",
        "title": "Find the classroom moment",
        "text": "We break competencies into scenarios, triggers, emotions, and teachable skills — the moments teachers actually see on the carpet, in line, or at recess."
      },
      {
        "step": "3",
        "title": "Deliver through story",
        "text": "Rex & Dino social stories give children a narrative mirror, discussion prompts, and practice — Story → Discussion → Activity → Reflection."
      }
    ]
  },
  "casel": [
    {
      "id": "self-awareness",
      "name": "Self-Awareness",
      "nameZh": "自我意识",
      "order": 1,
      "description": "The abilities to understand one's own emotions, thoughts, and values and how they influence behavior across contexts.",
      "classroomFocus": "Naming feelings, noticing body signals, recognizing strengths and limits",
      "storyApproach": "Stories help children pause and identify what is happening inside before they act — the Feeling Thermometer, calm-down cues, and \"name it to tame it\" moments.",
      "exampleMoments": ["Big feelings at carpet", "Noticing when volume rises", "Knowing when you need a break"],
      "keywords": ["notice", "feeling", "body signal", "name the feeling", "aware"]
    },
    {
      "id": "self-management",
      "name": "Self-Management",
      "nameZh": "自我管理",
      "order": 2,
      "description": "The abilities to manage one's emotions, thoughts, and behaviors effectively in different situations and to achieve goals.",
      "classroomFocus": "Impulse control, waiting, transitions, calming strategies, task persistence",
      "storyApproach": "Our largest story lane — waiting tokens, raise-hand routines, safe hands, and finish-what-you-start scripts for independent work.",
      "exampleMoments": ["Blurting during sharing", "Waiting in line", "Stopping when the timer rings"],
      "keywords": ["calm", "wait", "impulse", "regulat", "self control", "volume", "safe hands", "focus", "transition"]
    },
    {
      "id": "social-awareness",
      "name": "Social Awareness",
      "nameZh": "社会意识",
      "order": 3,
      "description": "The abilities to understand the perspectives of and empathize with others, including those from diverse backgrounds and cultures.",
      "classroomFocus": "Personal space, reading others' feelings, inclusion, fairness",
      "storyApproach": "Stories place Rex in group situations where he must notice how his body and words land on classmates — space bubbles, listening faces, and left-out moments.",
      "exampleMoments": ["Personal space on the rug", "A friend looks sad", "Game rules feel unfair"],
      "keywords": ["personal space", "perspective", "others", "empathy", "include", "left out"]
    },
    {
      "id": "relationship-skills",
      "name": "Relationship Skills",
      "nameZh": "人际关系",
      "order": 4,
      "description": "The abilities to establish and maintain healthy and supportive relationships and to navigate settings with diverse individuals and groups.",
      "classroomFocus": "Cooperation, turn-taking, apologies, repair after conflict, communication",
      "storyApproach": "Friendship repair stories, fair-turn games, and apologize-and-fix scripts — because peer relationships are where SEL is tested every day.",
      "exampleMoments": ["Saying sorry after grabbing", "Sharing materials fairly", "Rejoining group work"],
      "keywords": ["friend", "apolog", "sorry", "share", "repair", "fair", "turn", "cooperat"]
    },
    {
      "id": "responsible-decision-making",
      "name": "Responsible Decision-Making",
      "nameZh": "负责任决策",
      "order": 5,
      "description": "The abilities to make caring and constructive choices about personal behavior and social interactions across situations.",
      "classroomFocus": "Choices and consequences, flexible thinking, trying again after mistakes",
      "storyApproach": "When plans change or mistakes happen, stories model a next-step choice — flexible thinking, problem-solving, and our Thinking Skills bridge into judgment.",
      "exampleMoments": ["Hearing \"no\" calmly", "Trying a new way", "Fixing a mistake after blurting"],
      "keywords": ["choice", "decision", "try again", "mistake", "flexible", "plan", "problem solv"]
    }
  ],
