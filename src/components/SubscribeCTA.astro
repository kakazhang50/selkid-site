---
import { site, freeSample } from '@/lib/site';
import SubscribeForm from '@/components/SubscribeForm.astro';

interface Props {
  compact?: boolean;
  dark?: boolean;
  inline?: boolean;
  context?: string;
  id?: string;
  eyebrow?: string;
  title?: string;
  description?: string;
  buttonLabel?: string;
}

const {
  compact = false,
  dark = false,
  inline = false,
  context = 'form',
  id,
  eyebrow = 'Free for educators',
  title = `Get ${freeSample.unitTitle}`,
  description = freeSample.ctaDescription,
  buttonLabel = compact ? 'Get sample' : 'Get free sample',
} = Astro.props;

const hasFormspree = Boolean(site.subscribeEndpoint?.trim());
const showHeader = !inline && (eyebrow || title || description);
---

{
  inline ? (
    <SubscribeForm
      compact={compact}
      context={context}
      buttonLabel={buttonLabel}
      class="footer-email-form"
    />
  ) : (
    <section class:list={['subscribe-band', dark && 'subscribe-band--dark']} id={id}>
      <div class="subscribe-inner">
        {showHeader && (
          <div>
            {!compact && eyebrow && <p class="eyebrow">{eyebrow}</p>}
            {title && <h2>{title}</h2>}
            {description && <p>{description}</p>}
          </div>
        )}
        <SubscribeForm compact={compact} context={context} buttonLabel={buttonLabel} />
        {!compact && !hasFormspree && <p class="form-fine subscribe-band-fine">No spam. Unsubscribe anytime.</p>}
      </div>
    </section>
  )
}
