---
import { educationMatrix, catalog, pillarLink } from '@/lib/catalog';
import { selFramework } from '@/lib/selFramework';

const counts = catalog.domainCounts || {};
---

<div class="matrix-progression">
  {
    educationMatrix.progression.map((p) => {
      const count = catalog.pillars[p.pillar as keyof typeof catalog.pillars] || 0;
      return (
        <article class="matrix-pillar">
          <span class="matrix-order">{p.order}</span>
          <p class="matrix-tagline">{p.tagline}</p>
          <h3>{p.name}</h3>
          <p class="matrix-grades">
            {p.grades}
            {'status' in p && p.status ? ` · ${p.status}` : ''}
          </p>
          <p>{p.description}</p>
          <p class="matrix-count">
            <strong>{count}+</strong> resources
          </p>
          <a class="pillar-link" href={pillarLink(p.link)}>
            Explore {p.name}
          </a>
        </article>
      );
    })
  }
</div>
<div class="matrix-casel">
  <h3>Rooted in the CASEL Framework</h3>
  <p class="matrix-casel-lead">SEL Foundation stories map to all five U.S. SEL core competencies — then drill down by classroom domain.</p>
  <div class="casel-tags">
    {
      selFramework.casel.map((c) => (
        <a class="casel-tag casel-tag--link" href={`/sel-stories?casel=${c.id}`}>
          <strong>{c.name}</strong>
        </a>
      ))
    }
  </div>
  <p class="matrix-casel-more"><a href="/learning-system#casel">See how CASEL powers SELKID →</a></p>
</div>
<div class="matrix-domains">
  <h3>SEL story domains</h3>
  <div class="domain-grid">
    {
      educationMatrix.selDomains.map((d) => (
        <a class="domain-chip" href={`/sel-stories?category=${d.id}`}>
          <strong>{d.name}</strong>
          <span>{counts[d.id] || 0} stories</span>
          <em>{d.focus}</em>
        </a>
      ))
    }
  </div>
</div>
