---
import { site } from '@/lib/site';
import { catalog } from '@/lib/catalog';

interface Props {
  hero?: boolean;
}

const { hero = false } = Astro.props;

const navItems = [
  { href: '/learning-system', label: 'Learning System' },
  { href: '/ai-cognition', label: 'AI Cognition' },
  { href: '/sel-stories', label: 'SEL Stories' },
  { href: '/thinking-skills', label: 'Thinking Skills' },
  { href: '/rex-dino', label: 'Rex & Dino' },
  { href: '/educator-notes', label: 'Educator Notes' },
  { href: '/free-resources', label: 'Free Resources' },
  { href: '/about', label: 'About' },
];

const pathname = Astro.url.pathname;
const total = catalog.totalProducts || catalog.products.length;
---

<header class:list={['site-header', hero && 'site-header--hero']}>
  <div class="header-inner">
    <a class="brand" href="/" aria-label="SELKID home">
      <span class="brand-mark">SK</span>
      <span><strong>{site.brandName}</strong><small>{site.tagline}</small></span>
    </a>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
    <nav class="nav" id="site-nav" aria-label="Main navigation">
      {
        navItems.map((item) => {
          const active = pathname === item.href || pathname.startsWith(item.href + '/');
          return (
            <a href={item.href} class:list={[active && 'active']} aria-current={active ? 'page' : undefined}>
              {item.label}
            </a>
          );
        })
      }
    </nav>
    <a class="nav-cta" href={site.tptStore} target="_blank" rel="noopener">Shop on TPT</a>
  </div>
</header>
