---
import { site } from '@/lib/site';
import { catalog } from '@/lib/catalog';

interface Props {
  hero?: boolean;
}

const { hero = false } = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/learning-system', label: 'Learning System' },
  { href: '/sel-stories', label: 'SEL Stories' },
  { href: '/thinking-skills', label: 'Thinking Skills' },
  { href: '/ai-cognition', label: 'AI Cognition' },
  { href: '/educator-notes', label: 'Educator Notes' },
];

function isNavActive(href: string, pathname: string): boolean {
  if (href === '/') return pathname === '/' || pathname === '/index.html';
  return pathname === href || pathname.startsWith(href + '/');
}

const pathname = Astro.url.pathname;
const total = catalog.totalProducts || catalog.products.length;
---

<header class:list={['site-header', hero && 'site-header--hero']}>
  <div class="header-inner">
    <a class="brand" href="/" aria-label="SELKID home">
      <img
        class="brand-logo"
        src={site.brandLogo || '/assets/brand/selkid-logo.png'}
        alt=""
        width="48"
        height="48"
      />
      <span><strong>{site.brandName}</strong><small>{site.tagline}</small></span>
    </a>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
      <nav class="nav" id="site-nav" aria-label="Main navigation">
      {
        navItems.map((item) => {
          const active = isNavActive(item.href, pathname);
          return (
            <a href={item.href} class:list={[active && 'active']} aria-current={active ? 'page' : undefined}>
              {item.label}
            </a>
          );
        })
      }
      <div class="nav-drawer-ctas">
        <a class="nav-cta nav-cta--sample" href="/free-resources#subscribe">Get free sample</a>
        <a class="nav-cta" href={site.tptStore} target="_blank" rel="noopener">TPT Store</a>
      </div>
    </nav>
    <div class="header-ctas" aria-hidden="false">
      <a class="nav-cta nav-cta--sample" href="/free-resources#subscribe">Get free sample</a>
      <a class="nav-cta" href={site.tptStore} target="_blank" rel="noopener">TPT Store</a>
    </div>
  </div>
</header>
