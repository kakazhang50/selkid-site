---
import { site } from '@/lib/site';
import { catalog } from '@/lib/catalog';

const total = catalog.totalProducts || catalog.products.length;
const hasMailerLite = Boolean(site.mailerLiteFormId?.trim());
const logo = site.brandLogo || '/assets/brand/selkid-logo.png';
---

<section class="hero hero--home">
  <div class="hero-home-shell">
    <div class="hero-home-brand">
      <img
        class="hero-home-logo"
        src={logo}
        alt="SELKID — Social Emotional Learning"
        width="160"
        height="160"
        fetchpriority="high"
      />
      <div class="hero-home-brand-copy">
        <p class="eyebrow">SELKID · Story-based learning</p>
        <h1>{site.tagline}</h1>
        <p class="hero-home-deck">
          CASEL-aligned SEL for K–2 — plus thinking skills and Rex &amp; Dino's AI cognition series.
        </p>
      </div>
    </div>

    <div class="hero-home-grid">
      <div class="hero-home-main">
        <blockquote class="hero-home-belief" aria-label="SELKID brand belief">
          <p class="brand-belief-lead">{site.brandBeliefLead}</p>
          <p class="brand-belief-sub">{site.brandBeliefSub}</p>
          <p class="brand-belief-body">{site.brandBeliefBody}</p>
        </blockquote>

        <div class="hero-home-subscribe" id="subscribe">
          <div class="hero-home-subscribe-head">
            <p class="eyebrow">Free for educators</p>
            <h2>Get Unit 1: Training Data</h2>
            <p class="hero-home-subscribe-lead">
              Free AI cognition sample · new story launches · classroom-ready downloads.
            </p>
          </div>
          {
            hasMailerLite ? (
              <div class="ml-form-embed hero-home-form">
                <div class="ml-embedded" data-form={site.mailerLiteFormId} />
              </div>
            ) : (
              <form
                class="email-form subscribe-form hero-home-form"
                data-email-form
                data-form-context="homepage-hero"
                data-free-sample={site.freeSampleUrl || ''}
                data-endpoint={site.subscribeEndpoint || ''}
              >
                <input type="email" name="email" placeholder="your@email.com" required aria-label="Email" />
                <button class="btn btn-primary" type="submit">Get free sample</button>
                <p class="form-note" />
              </form>
            )
          }
          <p class="form-fine">No spam. Unsubscribe anytime.</p>
        </div>

        <div class="hero-home-meta">
          <ul class="hero-proof hero-proof--chips" aria-label="Brand highlights">
            <li>CASEL aligned</li>
            <li>Scenario × Trigger × Emotion × Skill</li>
            <li>{total}+ on TPT</li>
          </ul>
          <div class="hero-home-links">
            <a href="/learning-system">Learning System</a>
            <span aria-hidden="true">·</span>
            <a href="/ai-cognition">AI Cognition</a>
          </div>
        </div>
      </div>

      <aside class="hero-home-visual" aria-label="Rex and Dino comic preview">
        <img
          src="/assets/comics/training-data-p1.png"
          alt="Rex and Dino — Training Data comic page"
          width="480"
          height="620"
          loading="eager"
        />
      </aside>
    </div>
  </div>
</section>
