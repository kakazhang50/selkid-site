---
import { site, freeSample } from '@/lib/site';
import { catalog } from '@/lib/catalog';
import SubscribeForm from '@/components/SubscribeForm.astro';

const total = catalog.totalProducts || catalog.products.length;
const pillars = catalog.pillars;
const logo = site.brandLogo || '/assets/brand/selkid-logo.png';
---

<section class="hero hero--home">
  <div class="hero-home-shell">
    <div class="hero-home-brand">
      <img
        class="hero-home-logo"
        src={logo}
        alt="SELKID — Social Emotional Learning"
        width="140"
        height="140"
        fetchpriority="high"
      />
      <div class="hero-home-brand-copy">
        <p class="eyebrow">SELKID · Story-based learning</p>
        <h1>{site.tagline}</h1>
        <p class="hero-home-deck">
          SEL for K–2 · Thinking skills for K–2 · AI literacy for Grades 3–6 — Rex &amp; Dino in Maple Forest.
        </p>
      </div>
    </div>

    <div class="hero-home-body">
      <div class="hero-home-primary">
        <div class="hero-home-subscribe" id="subscribe">
          <div class="hero-home-subscribe-head">
            <p class="eyebrow">Free for educators</p>
            <h2>Get {freeSample.unitTitle}</h2>
            <p class="hero-home-subscribe-lead">{freeSample.heroLead}</p>
          </div>
          <ul class="subscribe-perks subscribe-perks--inline" aria-label="What's included">
            {
              freeSample.perks.map((perk) => (
                <li>{perk}</li>
              ))
            }
          </ul>
          <SubscribeForm
            class="hero-home-form"
            context="homepage-hero"
            placeholder="Teacher or parent email"
            buttonLabel="Get free sample"
          />
          <p class="form-fine">No spam. Unsubscribe anytime.</p>
        </div>

        <div class="hero-home-actions">
          <a class="btn btn-secondary" href="/sel-stories">Browse SEL stories</a>
          <a class="btn btn-ghost" href="/learning-system">See how it works</a>
        </div>
      </div>

      <aside class="hero-home-visual" aria-label="Rex and Dino comic preview">
        <a class="hero-visual-link" href="/free-resources">
          <span class="hero-visual-badge">Unit 1 · Free sample</span>
          <img
            src="/assets/comics/training-data-p1.png"
            alt="Rex and Dino — Training Data comic page"
            width="480"
            height="620"
            loading="eager"
          />
        </a>
      </aside>
    </div>

    <div class="hero-trust-stats" aria-label="SELKID at a glance">
      <div class="hero-trust-stat">
        <strong>{total}+</strong>
        <span>Classroom stories</span>
      </div>
      <div class="hero-trust-stat">
        <strong>3</strong>
        <span>Learning pillars</span>
      </div>
      <div class="hero-trust-stat">
        <strong>{pillars.sel}+</strong>
        <span>SEL stories</span>
      </div>
      <div class="hero-trust-stat">
        <strong>{pillars.ai}</strong>
        <span>AI units</span>
      </div>
    </div>
  </div>
</section>
