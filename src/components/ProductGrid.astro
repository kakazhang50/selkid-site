---
import ProductCard from '@/components/ProductCard.astro';
import type { Product } from '@/lib/catalog';

interface Props {
  products: Product[];
  catalogMode?: boolean;
  catalogGrid?: boolean;
  pillar?: string;
}

const { products, catalogMode = false, catalogGrid = false, pillar = '' } = Astro.props;
---

<div
  class="product-grid catalog-grid"
  data-catalog-grid={catalogGrid ? '' : undefined}
  data-catalog={catalogGrid ? pillar : undefined}
  data-paginate={catalogGrid ? '' : undefined}
  aria-live={catalogGrid ? 'polite' : undefined}
>
  {
    products.length === 0 ? (
      <p class="grid-empty">No resources match this filter.</p>
    ) : (
      products.map((product) => <ProductCard product={product} catalogMode={catalogMode} />)
    )
  }
</div>
