---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { site, pageTitle } from '@/lib/site';
import { absoluteUrl, buildJsonLdGraph, webPageSchema, type BreadcrumbItem } from '@/lib/seo';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  heroHeader?: boolean;
  canonical?: string;
  siteCompact?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  pageType?: 'WebPage' | 'AboutPage' | 'CollectionPage';
  jsonLdExtra?: Record<string, unknown>[];
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  ogImage = '/assets/hero-maple-forest.png',
  ogImageAlt = `${site.brandName} — ${site.tagline}`,
  ogType = 'website',
  heroHeader = false,
  canonical: canonicalOverride,
  siteCompact = true,
  breadcrumbs = [],
  jsonLdExtra = [],
  pageType = 'WebPage',
  publishedTime,
  modifiedTime,
  noindex = false,
} = Astro.props;

const fullTitle = pageTitle(title);
const canonical = canonicalOverride ?? new URL(Astro.url.pathname, Astro.site);
const canonicalHref = canonical.toString();
const ogImageUrl = absoluteUrl(ogImage);

const pageGraph = [
  webPageSchema({
    name: title ? fullTitle : `${site.brandName} | ${site.tagline}`,
    description,
    url: canonicalHref,
    type: pageType,
  }),
  ...jsonLdExtra,
];

const jsonLd = buildJsonLdGraph(pageGraph);
const robots = noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large';
const articleMeta = ogType === 'article';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content={site.brandName} />
    <meta name="theme-color" content="#3d6b52" />
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalHref} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-readable site summary" />
    <link rel="sitemap" href="/sitemap-index.xml" type="application/xml" title="Sitemap" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta property="og:site_name" content={site.brandName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    {articleMeta && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {articleMeta && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {articleMeta && publishedTime && !modifiedTime && (
      <meta property="article:modified_time" content={publishedTime} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {
      site.cloudflareWebAnalyticsToken?.trim() && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${site.cloudflareWebAnalyticsToken.trim()}"}`}
        />
      )
    }
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header hero={heroHeader} />
    <main id="main-content" class:list={[siteCompact && 'site-compact']}>
      <Breadcrumbs items={breadcrumbs} />
      <slot />
    </main>
    <Footer />
    <script src="/scripts/interactive.js" defer></script>
  </body>
</html>
